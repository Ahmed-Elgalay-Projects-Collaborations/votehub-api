NODE_ENV=development
PORT=3100
MONGO_URI=mongodb://localhost:27017/votehub
MONGO_URI_DOCKER=mongodb://mongo:27017/votehub
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ENABLE_COOKIE_AUTH=true
AUTH_COOKIE_NAME=votehub_access_token
CSRF_COOKIE_NAME=votehub_csrf_token
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=3600000
CSRF_COOKIE_MAX_AGE_MS=3600000
ENABLE_METRICS=true
LOG_DIR=logs
BODY_LIMIT=100kb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=200
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_LOCK_WINDOW_SECONDS=900
AUDIT_SALT=replace_with_random_audit_salt
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
