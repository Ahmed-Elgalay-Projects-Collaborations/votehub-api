NODE_ENV=development
PORT=3100
MONGO_URI=mongodb://localhost:27017/votehub
MONGO_URI_DOCKER=mongodb://mongo:27017/votehub
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
OTP_CHALLENGE_EXPIRES_IN=5m
ADMIN_STEP_UP_EXPIRES_IN=10m
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:3100
CORS_ORIGINS=http://localhost:3000
ENABLE_COOKIE_AUTH=true
AUTH_COOKIE_NAME=votehub_access_token
CSRF_COOKIE_NAME=votehub_csrf_token
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=3600000
CSRF_COOKIE_MAX_AGE_MS=3600000
EMAIL_VERIFICATION_TOKEN_EXPIRES_MINUTES=60
EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verify-email
OTP_ISSUER=VoteHub
OTP_ENCRYPTION_KEY=replace_with_32_byte_secret_or_64_hex_chars
VOTE_ENCRYPTION_KEY=replace_with_32_byte_secret_or_64_hex_chars
OTP_MAX_FAILED_ATTEMPTS=5
OTP_LOCK_WINDOW_SECONDS=300
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@votehub.local
ENABLE_METRICS=true
METRICS_REQUIRE_AUTH=false
METRICS_TOKEN=
LOG_DIR=logs
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
BODY_LIMIT=100kb
TRUST_PROXY=1
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=200
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_LOCK_WINDOW_SECONDS=900
LOGIN_LOCK_MAX_SECONDS=86400
AUDIT_SIGNING_KEY=replace_with_random_signing_key
RECEIPT_SIGNING_KEY=replace_with_random_receipt_signing_key
REPLAY_PROTECTION_TTL_SECONDS=86400
RISK_SCORE_DECAY_PER_MINUTE=1
RISK_MEDIUM_THRESHOLD=25
RISK_HIGH_THRESHOLD=45
RISK_CRITICAL_THRESHOLD=70
RISK_BLOCK_DURATION_SECONDS=900
AUDIT_SALT=replace_with_random_audit_salt
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
