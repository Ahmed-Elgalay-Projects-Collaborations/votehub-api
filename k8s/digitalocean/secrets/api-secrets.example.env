MONGO_URI=mongodb+srv://<atlas-user>:<atlas-pass>@<atlas-cluster>/<db-name>?retryWrites=true&w=majority&appName=votehub
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
OTP_ENCRYPTION_KEY=replace_with_32_byte_secret_or_64_hex_chars
VOTE_ENCRYPTION_KEY=replace_with_32_byte_secret_or_64_hex_chars
AUDIT_SIGNING_KEY=replace_with_random_signing_key_at_least_32_chars
RECEIPT_SIGNING_KEY=replace_with_random_receipt_signing_key_at_least_32_chars
AUDIT_SALT=replace_with_random_audit_salt
METRICS_TOKEN=replace_with_metrics_bearer_token
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@votehub.example.com
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
SMTP_DNS_TIMEOUT_MS=10000
SMTP_IP_FAMILY=0
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
