    {
      "name": "Elections",
      "item": [
        {
          "name": "List Elections",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/elections",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
