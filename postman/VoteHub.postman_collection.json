        },
        {
          "name": "Create Election (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const election = json?.data?.election;",
                  "if (election) {",
                  "  pm.collectionVariables.set('electionId', election.id || election._id);",
                  "  if (Array.isArray(election.options) && election.options.length > 0) {",
                  "    pm.collectionVariables.set('optionId', election.options[0].id || election.options[0]._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrfToken}}"
              },
              {
                "key": "X-Admin-Step-Up-Token",
                "value": "{{adminStepUpToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Student Council Election\",\n  \"description\": \"Annual student council vote\",\n  \"type\": \"election\",\n  \"options\": [\n    {\n      \"label\": \"Candidate A\",\n      \"description\": \"Platform A\"\n    },\n    {\n      \"label\": \"Candidate B\",\n      \"description\": \"Platform B\"\n    }\n  ],\n  \"startsAt\": \"2025-01-01T00:00:00.000Z\",\n  \"endsAt\": \"2030-12-31T23:59:59.000Z\",\n  \"maxSelections\": 1,\n  \"resultsVisibility\": \"after_close\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/elections",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "elections"
              ]
            }
          }
        },
        {
          "name": "Get Election by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/elections/{{electionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "elections",
                "{{electionId}}"
              ]
            }
          }
        },
